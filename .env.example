# Copy to .env and adjust. Everything has safe local defaults;
# CHANGE ALL SECRETS before any shared or production deployment.
POSTGRES_USER=bakery
POSTGRES_PASSWORD=bakery
POSTGRES_DB=bakery
AUTH_TOKEN_SECRET=local-dev-token-secret
LOG_LEVEL=info

# Razorpay (optional locally — payment-service falls back to mock mode).
# Get keys from https://dashboard.razorpay.com -> Settings -> API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
